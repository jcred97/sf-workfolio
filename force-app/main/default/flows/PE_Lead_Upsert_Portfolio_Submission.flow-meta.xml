        </defaultConnector>
        <defaultConnectorLabel>Email is not sent</defaultConnectorLabel>
        <rules>
            <name>Email_is_Sent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>isEmailSent</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
